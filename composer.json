{
    "name": "padosoft/laravel-flow",
    "description": "DX-first workflow / saga / compensation engine for Laravel with native dry-run, reverse-order compensation, approval gate, business impact tracking, and immutable audit trail.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "laravel",
        "workflow",
        "saga",
        "dry-run",
        "approval",
        "compensation",
        "audit-trail",
        "business-impact",
        "orchestration"
    ],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/queue": "^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0"
    },
    "suggest": {
        "padosoft/laravel-patent-box-tracker": "Tracks R&D activity (Italian Patent Box) across repositories that depend on laravel-flow — useful when flow definitions are part of a tax-deductible R&D project."
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\LaravelFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\LaravelFlow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\LaravelFlow\\LaravelFlowServiceProvider"
            ],
            "aliases": {
                "Flow": "Padosoft\\LaravelFlow\\Facades\\Flow"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
