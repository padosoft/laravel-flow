{
    "name": "padosoft/laravel-flow",
    "description": "DX-first workflow / saga / compensation engine for Laravel with native dry-run, reverse-order compensation, business impact tracking, opt-in persistence, and audit events.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "laravel",
        "workflow",
        "saga",
        "dry-run",
        "compensation",
        "audit-trail",
        "business-impact",
        "orchestration"
    ],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5|^12.5"
    },
    "suggest": {
        "illuminate/queue": "Required for Flow::dispatch() queued execution; configure your Laravel queue connection/worker for async processing.",
        "padosoft/laravel-patent-box-tracker": "Tracks R&D activity (Italian Patent Box) across repositories that depend on laravel-flow — useful when flow definitions are part of a tax-deductible R&D project."
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\LaravelFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\LaravelFlow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\LaravelFlow\\LaravelFlowServiceProvider"
            ],
            "aliases": {
                "Flow": "Padosoft\\LaravelFlow\\Facades\\Flow"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse --no-progress --memory-limit=512M",
        "format:test": "pint --test",
        "quality": [
            "@format:test",
            "@analyse",
            "@test"
        ],
        "test": [
            "phpunit --testsuite Unit",
            "phpunit --testsuite Architecture"
        ]
    }
}
