{
    "name": "padosoft/laravel-flow",
    "description": "DX-first workflow engine for Laravel with dry-run, compensation, approval gate, and business impact tracking",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["laravel", "workflow", "saga", "dry-run", "approval", "compensation"],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lopadova\\LaravelFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lopadova\\LaravelFlow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lopadova\\LaravelFlow\\LaravelFlowServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
