          "title": "Docs",
          "path": "/"
        },
        {
          "title": "GitHub",
          "url": "https://github.com/padosoft/laravel-flow"
        },
        {
          "title": "Packagist",
          "url": "https://packagist.org/packages/padosoft/laravel-flow"
        }
      ],
      "right": [
        {
          "title": "Padosoft",
          "url": "https://padosoft.com"
        }
      ]
    }
  },
  "footer": {
    "style": "minimal",
    "content": "laravel-flow documentation. Built by Padosoft under Apache-2.0."
