{
  "title": "laravel-flow",
  "description": "DX-first workflow, saga, compensation, dry-run, and audit engine for Laravel.",
  "url": "https://doc.laravel-flow.padosoft.com",
  "src": "docs-site",
  "out": "_site",
  "base": "/",
  "favicon": "assets/favicon.svg",
  "copyCode": true,
  "pageNavigation": true,
  "minify": true,
  "theme": {
